{
  "$schema": "https://raw.githubusercontent.com/nicholasrice/nicholasrice/refs/heads/main/schemas/tauri-v2.json",
  "productName": "Desktop Pet",
  "version": "0.1.0",
  "identifier": "com.desktop-pet.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "pet",
        "title": "Desktop Pet",
        "url": "/pet",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "width": 300,
        "height": 300,
        "x": 100,
        "y": 100,
        "resizable": false,
        "skipTaskbar": true,
        "visibleOnAllWorkspaces": true,
        "shadow": false
      },
      {
        "label": "chat",
        "title": "Desktop Pet Chat",
        "url": "/chat",
        "width": 400,
        "height": 600,
        "decorations": false,
        "visible": false,
        "resizable": true,
        "transparent": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
